# pws-mes-tools MCP 환경변수 예시
# 이 파일을 복사해서 .env 로 만들고 실제 값을 채운 뒤,
# 셸 환경변수로 로드한 상태에서 claude 를 실행하세요. (.env 는 git 에 커밋하지 않습니다)
#
#   Windows PowerShell:  Get-Content .env | ForEach-Object { if ($_ -match '^\s*([^#=]+)=(.*)$') { $env:($matches[1].Trim()) = $matches[2].Trim() } }
#   Git Bash / Linux:    export $(grep -v '^#' .env | xargs)
#
# MSSQL 접속 문자열 (SITE_PEOPLEWORKS)
MSSQL_CONNECTION_STRING=Data Source=<서버IP>; Initial Catalog=SITE_PEOPLEWORKS; User ID=<계정>; Password=<비밀번호>; TrustServerCertificate=True;
